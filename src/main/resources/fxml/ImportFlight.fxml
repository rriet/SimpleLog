<AnchorPane id="AnchorPane" fx:id="anchorPane" maxHeight="760.0" maxWidth="900.0" minHeight="760.0" minWidth="900.0" prefHeight="760.0" prefWidth="900.0" stylesheets="@../styles/Tab.css" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.rietcorrea.simplelog.ImportFlightController">
    <children>
      <VBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
              <TabPane fx:id="tabPane" focusTraversable="false" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
                  <tabs>
                      <Tab fx:id="tabDate" text="Date">
                          <content>
                              <AnchorPane minHeight="0.0" minWidth="0.0">
                           <children>
                              <VBox prefHeight="200.0" prefWidth="100.0" spacing="5.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                 <children>
                                    <Label text="Flight Import Wizzard">
                                       <font>
                                          <Font size="18.0" />
                                       </font>
                                    </Label>
                                    <Label text="Note: Importing databases is a complex procedure, and the success will depend on the quality of the file you are trying to import.&#10;&#10;This wizzard tries to verify that the correct data is consistently available in the file and will display warning messages on the bottom if any problems are found. The best way to proceed is to open the file in a plain text editor  or excel and fix the problem.&#10;&#10;The importing tool will follow the &quot;Duplicated Flight&quot; selection when the flight beeing imported has the same Chocks-Off date and Time of a existing flight. If you have more than one flight in the same day with invalid departure time, they will be considered duplicated." textAlignment="JUSTIFY" wrapText="true" />
                                    <Label text="Items in RED are required." textFill="RED" />
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="Duplicated Flight:" textFill="RED">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbDuplicatedFlight" prefWidth="300.0" />
                                       </children>
                                    </HBox>
                                    <Label text="Select the date and time format that is used in the file beeing imported.&#10;&#10;Note: Epoch time is is a system for describing a point in time. It is the number of seconds that have elapsed since the Unix epoch, minus leap seconds; the Unix epoch is 00:00:00 UTC on 1 January 1970.&#10;" wrapText="true" />
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="Date and Time Format:" textFill="RED">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbDateFormat" onAction="#cmbDateFormatAction" prefWidth="300.0" />
                                       </children>
                                    </HBox>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label fx:id="lblDepDate" text="Flight departure date:" textFill="RED">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbDate" prefWidth="350.0" />
                                       </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <VBox spacing="5.0">
                                             <children>
                                                <HBox spacing="5.0">
                                                   <children>
                                                      <Label fx:id="lblDepTime" text="Flight Chocks-Off Time:">
                                                         <font>
                                                            <Font size="18.0" />
                                                         </font>
                                                      </Label>
                                                      <ComboBox fx:id="cmbDepTime" prefWidth="350.0" />
                                                   </children>
                                                </HBox>
                                                <HBox spacing="5.0">
                                                   <children>
                                                      <Label fx:id="lblArrTime" text="Flight Chocks-On Time:">
                                                         <font>
                                                            <Font size="18.0" />
                                                         </font>
                                                      </Label>
                                                      <ComboBox fx:id="cmbArrTime" prefWidth="350.0" />
                                                   </children>
                                                </HBox>
                                             </children>
                                             <padding>
                                                <Insets right="10.0" />
                                             </padding>
                                          </VBox>
                                          <CheckBox fx:id="chkIgnoreDepArrTime" mnemonicParsing="false" text="Ignore Time Errors">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </CheckBox>
                                       </children>
                                    </HBox>
                                    <Label text="If your file doen't have the departure and arrival time for all the flights, you may choose to &quot;Ignore Time Errors&quot;. With this option selected, any Chocks-Off or Chocks-On time that is not valid or in the format HH:MM, will be set to 00:00 UTC.&#10;&#10;&quot;Ignore Time Errors&quot; option is not available if you are using EPOCH format.&#10;&#10;You must have valid chocks-off and chocks-on times if you plan to Re-calculate landings and/or night time." wrapText="true" />
                                    <VBox spacing="5.0" VBox.vgrow="ALWAYS">
                                       <children>
                                          <CheckBox fx:id="chkReCalcToLdg" mnemonicParsing="false" onAction="#clickReCalcToLdg" text="Recalculate Take-offs and Landings">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </CheckBox>
                                          <CheckBox fx:id="chkReCalcTimeNight" mnemonicParsing="false" onAction="#clickReCalcNightTime" text="Recalculate Night Time">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </CheckBox>
                                       </children>
                                       <padding>
                                          <Insets left="10.0" top="10.0" />
                                       </padding>
                                    </VBox>
                                    <HBox alignment="CENTER_RIGHT">
                                       <children>
                                          <Button fx:id="btnNextDate" minWidth="120.0" mnemonicParsing="false" onAction="#btnNextDateAction" text="Next" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </AnchorPane>
                          </content>
                      </Tab>
                  <Tab fx:id="tabRmk" text="RMK">
                    <content>
                      <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <VBox layoutX="133.0" layoutY="169.0" spacing="5.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                 <children>
                                    <Label text="Remarks and Notes">
                                       <font>
                                          <Font size="18.0" />
                                       </font>
                                    </Label>
                                    <Label text="Remarks and Private notes are text fields with maximum length of 500 character. Any text exceeding this length will be cropped to fit.&#10;&#10;Remarks are normally printed in the logbook.&#10;&#10;Private Notes will not be printed, they are only be used for searching a specific flight, and saving personal notes about a flight." wrapText="true" />
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="Flight Remarks:">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbRemarks" prefWidth="350.0" />
                                       </children>
                                    </HBox>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="Private Notes:">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbPrivateNotes" prefWidth="350.0" />
                                       </children>
                                    </HBox>
                                    <VBox VBox.vgrow="ALWAYS" />
                                    <HBox alignment="CENTER_RIGHT" spacing="5.0">
                                       <children>
                                          <Button mnemonicParsing="false" onAction="#btnBackRmkAction" prefWidth="120.0" text="Back" />
                                          <Button mnemonicParsing="false" onAction="#btnNextRmkAction" prefWidth="120.0" text="Next" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children></AnchorPane>
                    </content>
                  </Tab>
                  <Tab fx:id="tabLanding" text="Landing">
                    <content>
                      <AnchorPane minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                           <children>
                              <VBox prefHeight="200.0" prefWidth="100.0" spacing="5.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                 <children>
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="PF/PNF:">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbPfPnf" prefWidth="350.0" />
                                       </children>
                                    </HBox>
                                    <Label text="PF/PNF field is a column holding the pilot funciont during the flight. The valid inputs are:&#10;&#10;&quot;PF&quot; -  1 Take-off and 1 landing&#10;&quot;PNF&quot; - No take-off or landing&#10;&quot;PF/PNF&quot; - 1 Take-off and no landing&#10;&quot;PNF/PF&quot; - No take-off and 1 Landing&#10;&quot;IRP 3&quot; - No take-off or Landings, and flight time will count as 2/3 of the actual total time&#10;&quot;IRP 4&quot;- No Take-off or Landing, and flight flight time will count as 1/2 of the actual total time&#10;&#10;Note: Any invalid &quot;PF/PNF&quot; input will be considered PF.&#10;&#10;If the column is NOT selected, the importer will use the take-off and landing information to determine the PF/PNF status.&#10;&#10;To recalculate take-offs and landings, the system will use the departure and arrival times to calculate if take-off and landing was performed during day or night, according to the &quot;PF/PNF&quot; rules." wrapText="true" />
                                    <GridPane>
                                      <columnConstraints>
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="419.0" minWidth="10.0" prefWidth="184.0" />
                                        <ColumnConstraints hgrow="SOMETIMES" maxWidth="695.0" minWidth="10.0" prefWidth="657.0" />
                                      </columnConstraints>
                                      <rowConstraints>
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                        <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                      </rowConstraints>
                                       <children>
                                          <Label fx:id="lblToDay" text="Take-Off Day:" textFill="RED">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                             <GridPane.margin>
                                                <Insets left="10.0" />
                                             </GridPane.margin>
                                          </Label>
                                          <Label fx:id="lblToNight" text="Take-Off Night:" textFill="RED" GridPane.rowIndex="1">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                             <GridPane.margin>
                                                <Insets left="10.0" />
                                             </GridPane.margin>
                                          </Label>
                                          <Label fx:id="lblLdgDay" text="Landing Day:" textFill="RED" GridPane.rowIndex="2">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                             <GridPane.margin>
                                                <Insets left="10.0" />
                                             </GridPane.margin>
                                          </Label>
                                          <Label fx:id="lblLdgNight" text="Landing Night:" textFill="RED" GridPane.rowIndex="3">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                             <GridPane.margin>
                                                <Insets left="10.0" />
                                             </GridPane.margin>
                                          </Label>
                                          <ComboBox fx:id="cmbTakeOffDay" prefWidth="350.0" GridPane.columnIndex="1" />
                                          <ComboBox fx:id="cmbTakeOffNight" prefWidth="350.0" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                                          <ComboBox fx:id="cmbLandingDay" prefWidth="350.0" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                                          <ComboBox fx:id="cmbLandingNight" prefWidth="350.0" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                                       </children>
                                    </GridPane>
                                    <VBox VBox.vgrow="ALWAYS" />
                                    <HBox alignment="CENTER_RIGHT" spacing="5.0">
                                       <children>
                                          <Button mnemonicParsing="false" onAction="#btnBackLandingAction" prefWidth="120.0" text="Back" />
                                          <Button mnemonicParsing="false" onAction="#btnNextLandingAction" prefWidth="120.0" text="Next" />
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </AnchorPane>
                    </content>
                  </Tab>
                  <Tab fx:id="tabTimes" text="Times">
                    <content>
                      <AnchorPane minHeight="0.0" minWidth="0.0">
                           <children>
                              <VBox AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                 <children>
                                    <Label text="Flight Times:">
                                       <font>
                                          <Font size="18.0" />
                                       </font>
                                    </Label>
                                    <Label text="Flight times can be formatted as: &#10; - Formatted hour (hour : minutes) Example: &quot;0:34&quot; , &quot;1:43&quot;, &quot;03:22&quot;, &quot;11:05&quot;&#10; - Integer number (number of minutes)  Example: &quot;1&quot;, &quot;300&quot;, &quot;245&quot;&#10; - Decimal number (number of hours . decimal of the hour) Example: &quot;3.22&quot;, &quot;0.15&quot;, &quot;1&quot;, &quot;11.1&quot;&#10;&#10;The maximum values for hours are 23:59 or 1439 min or 23.93&#10;Note: Invalid Hours will fail the import." wrapText="true" />
                                    <HBox spacing="5.0">
                                       <children>
                                          <Label text="%LabelFlightTimeFormat">
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <ComboBox fx:id="cmbHourFormat" prefWidth="230.0" />
                                       </children>
                                    </HBox>
                                    <Label text="Recalculate IFR and Cross Country option will follow the main configurations.&#10;The recalculate Night Time option will use the Date, departure Time, arrival Time, departure Airport and arrival ariport to calculate the night time." wrapText="true" />
                                    <GridPane>
                                       <columnConstraints>
                                          <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="255.0" minWidth="100.0" prefWidth="240.0" />
                                          <ColumnConstraints hgrow="SOMETIMES" maxWidth="476.0" minWidth="10.0" prefWidth="329.0" />
                                          <ColumnConstraints hgrow="SOMETIMES" maxWidth="252.0" minWidth="120.0" prefWidth="252.0" />
                                       </columnConstraints>
                                       <rowConstraints>
                                          <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                       </rowConstraints>
                                       <VBox.margin>
                                          <Insets left="10.0" right="10.0" top="10.0" />
                                       </VBox.margin>
                                       <children>
                                          <Label text="%LabelFlightIfrTime">
                                             <padding>
                                                <Insets right="10.0" />
                                             </padding>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightCrossCountryTime" GridPane.rowIndex="1">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightNightTime" GridPane.rowIndex="2">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightPicTime" GridPane.rowIndex="3">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightSicTime" GridPane.rowIndex="5">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightDualTime" GridPane.rowIndex="6">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightInstructorTime" GridPane.rowIndex="7">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightSimulatorTime" GridPane.rowIndex="8">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightTotalTime" textFill="RED" GridPane.rowIndex="9">
                                             <GridPane.margin>
                                                <Insets right="10.0" />
                                             </GridPane.margin>
                                             <font>
                                                <Font size="18.0" />
                                             </font>
                                          </Label>
                                          <Label text="%LabelFlightPicusTime" GridPane.rowIndex="4">
