                  </Tab>
                      <Tab fx:id="tabType" text="Type">
                          <content>
                              <AnchorPane minHeight="0.0" minWidth="0.0">
                                  <VBox AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                      <children>
                                 <Label text="Aircraft Model">
                                    <font>
                                       <Font size="18.0" />
                                    </font>
                                 </Label>
                                 <Label text="Aircraft model must have a minimum of 2 characteres. Aircraft Model and Group must have a maximum of 20 characters.&#10;Valid Engine types are: Turbofan, Turboprop, Piston and Glider.&#10;&#10;Note: Any different value will be imported as Turbofan&#10;&#10;Note: MTOW must be a number. If it's not a valid number it will be imported as 0 (Zero)&#10;&#10;For the columns Multi-Pilot, Multi-Engine and EFIS, the values &quot;1&quot;, &quot;true&quot;, &quot;yes&quot;, &quot;sim&quot; and &quot;checked&quot; will be imported as true (checked box). All other values will be considered false (unchecked box).&#10;&#10;If you select to override model, models with the same &quot;Make and Model&quot; information will be overriten in the database. This will affect all the aircrafts using this model.&#10;" wrapText="true" />
                                          <GridPane>
                                              <columnConstraints>
                                                  <ColumnConstraints halignment="RIGHT" hgrow="SOMETIMES" maxWidth="255.0" minWidth="100.0" prefWidth="43.0" />
                                                  <ColumnConstraints hgrow="SOMETIMES" maxWidth="476.0" minWidth="10.0" prefWidth="476.0" />
                                       <ColumnConstraints />
                                              </columnConstraints>
                                              <rowConstraints>
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                  <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                       <RowConstraints minHeight="30.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                              </rowConstraints>
                                              <VBox.margin>
                                                  <Insets left="10.0" right="10.0" top="10.0" />
                                              </VBox.margin>
                                              <children>
                                                  <Label text="%LabelModelMakeAndModel" textFill="RED">
                                                      <padding>
                                                          <Insets right="10.0" />
